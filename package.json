{
  "name": "dawidrylko.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal website and blog of Dawid Ryłko, built with Astro.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "develop": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "serve": "astro preview",
    "clean": "rm -rf dist .astro",
    "type:check": "astro check",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,mjs,json,md}\"",
    "format:write": "prettier --write \"**/*.{astro,ts,tsx,js,mjs,json,md}\"",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "a11y:contrast": "node scripts/a11y/check-contrast.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.3",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "astro": "^7.0.6",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "**/*.{astro,ts,tsx,js,mjs,json,md}": "prettier --write",
    "**/*.{astro,ts,tsx,js,mjs}": "eslint --fix",
    "src/**/*.css": "stylelint --fix"
  },
  "prettier": {
    "arrowParens": "avoid",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "printWidth": 120,
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard"
    ],
    "ignoreFiles": [
      "src/styles/normalize.css"
    ],
    "rules": {
      "custom-property-pattern": null,
      "keyframes-name-pattern": null,
      "no-descending-specificity": null
    }
  }
}
