{
  "name": "dawidrylko.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal website and blog of Dawid Ryłko, built with Astro.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "develop": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "serve": "astro preview",
    "clean": "rm -rf dist .astro",
    "type:check": "astro check",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,mjs,json,md}\"",
    "format:write": "prettier --write \"**/*.{astro,ts,tsx,js,mjs,json,md}\"",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "a11y:contrast": "node helpers/a11y-contrast/check-contrast.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.2",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "astro": "^6.4.8",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "**/*.{astro,ts,tsx,js,mjs,json,md}": "prettier --write",
    "**/*.{astro,ts,tsx,js,mjs}": "eslint --fix",
    "src/**/*.css": "stylelint --fix"
  }
}
