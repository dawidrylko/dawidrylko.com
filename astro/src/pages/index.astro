---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Mermaid from '../components/Mermaid.tsx';

// Temporary navigation aid listing every post (newest first, like Gatsby's
// blog listing). The full blog/index parity comes in Phase 3.
const posts = (await getCollection('posts')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const chart = 'graph LR; Gatsby[Gatsby 5] --> Astro[Astro 6]; Astro --> Pages[GitHub Pages];';
---

<BaseLayout title="Astro PoC — dawidrylko.com" description="Astro migration spike for dawidrylko.com">
  <h1>Astro migration — all posts</h1>
  <p>Routing <strong>{posts.length}</strong> posts from <code>../content/pl</code> at their original URLs.</p>
  <ol>
    {
      posts.map(post => (
        <li>
          <a href={`/${post.id}/`}>{post.data.title}</a>
        </li>
      ))
    }
  </ol>

  <h2>Mermaid (React island)</h2>
  <Mermaid client:visible chart={chart} />
</BaseLayout>
