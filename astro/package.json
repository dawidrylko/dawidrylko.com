{
  "name": "dawidrylko-astro",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Astro migration spike (PoC) for dawidrylko.com — runs in parallel with the Gatsby site until cutover.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "type:check": "astro check",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,mjs,json,md}\"",
    "format:write": "prettier --write \"**/*.{astro,ts,tsx,js,mjs,json,md}\"",
    "lint:check": "eslint ."
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "astro": "^6.4.8",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
