---
import { SITE_METADATA } from '../data/site-metadata';

// Port of src/components/menu.tsx (nav + SiteNavigationElement JSON-LD).
const menu = SITE_METADATA.menu;
---

<nav class="menu">
  <ul>
    {
      menu.map(item => (
        <li>
          <a href={item.url}>
            <span>{item.name}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>
