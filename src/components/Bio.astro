---
import { Image } from 'astro:assets';
import avatar from '../assets/avatar.jpeg';
import { SITE_METADATA } from '../data/site-metadata';
import ExternalLink from './ExternalLink.astro';

// Port of src/components/bio.tsx (author card + Person JSON-LD).
const author = SITE_METADATA.author;
const social = SITE_METADATA.social;
---

<div class="bio">
  <Image class="avatar" src={avatar} width={60} height={60} layout="fixed" alt="Profile picture" />
  <div>
    <p class="name">{author.name}</p>
    <p class="job-title">{author.jobTitle}</p>
    <ul>
      <li>
        <a href={`mailto:${author.email}`}>Email</a>
      </li>
      {
        social.map(({ name, url, follow }) => (
          <li>
            <ExternalLink href={url} follow={follow}>
              {name}
            </ExternalLink>
          </li>
        ))
      }
    </ul>
  </div>
</div>
