---
// Port of src/components/table.tsx for plain string cells (e.g. the bio page).
// Pages with rich cells (links, icons) render their own <table> with the same
// structure.
interface Props {
  data: string[][];
  header?: string[];
  widthConfig?: string[];
  ariaLabel?: string;
}

const { data, header, widthConfig, ariaLabel } = Astro.props;
---

<div class="table-scroll" tabindex="0">
  <table aria-label={ariaLabel}>
    {
      widthConfig && (
        <colgroup>
          {widthConfig.map(width => (
            <col class={`col-w-${width.replace('%', '').trim()}`} />
          ))}
        </colgroup>
      )
    }
    {
      header && (
        <thead>
          <tr>
            {header.map(item => (
              <th scope="col">{item}</th>
            ))}
          </tr>
        </thead>
      )
    }
    <tbody>
      {
        data.map(row => (
          <tr>
            {row.map(cell => (
              <td>{cell}</td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
